// Prisma schema for MedAlign — Foundation slice
// See: docs/superpowers/specs/2026-07-10-backend-foundation-design.md §5

generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [citext]
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum AppRole {
  patient
  clinic
  admin
  superadmin

  @@map("app_role")
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                  String    @unique
  passwordHash           String    @map("password_hash")
  emailConfirmed         Boolean   @default(false) @map("email_confirmed")
  failedLoginCount       Int       @default(0) @map("failed_login_count")
  lockedUntil            DateTime? @map("locked_until") @db.Timestamptz
  recoveryPhoneEncrypted String?   @map("recovery_phone_encrypted")
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  roles          UserRole[]
  twoFactorCodes TwoFactorCode[]

  @@map("users")
}

model UserRole {
  id     String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId String  @map("user_id") @db.Uuid
  role   AppRole

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@map("user_roles")
}

model TwoFactorCode {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  codeHash   String    @map("code_hash")
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz
  attempts   Int       @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("two_factor_codes")
}

model AuditLog {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  actorUserId    String?  @map("actor_user_id") @db.Uuid
  actorRole      String?  @map("actor_role")
  ipAddress      String?  @map("ip_address")
  actionType     String   @map("action_type")
  affectedRecord String   @map("affected_record")
  previousValue  Json?    @map("previous_value")
  newValue       Json?    @map("new_value")
  notes          String?

  @@map("audit_log")
}

// Prisma schema for MedAlign — Foundation + Patient Journey + Clinic Applications slices
// See: docs/superpowers/specs/2026-07-10-backend-foundation-design.md §5
//      docs/superpowers/specs/2026-07-13-patient-journey-design.md §3
//      docs/superpowers/specs/2026-07-15-clinic-applications-design.md §3

generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [citext]
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum AppRole {
  patient
  clinic
  admin
  superadmin

  @@map("app_role")
}

enum AssessmentCategory {
  hormone
  peptide
  med_spa
  wellness

  @@map("assessment_category")
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                  String    @unique
  passwordHash           String    @map("password_hash")
  emailConfirmed         Boolean   @default(false) @map("email_confirmed")
  failedLoginCount       Int       @default(0) @map("failed_login_count")
  lockedUntil            DateTime? @map("locked_until") @db.Timestamptz
  recoveryPhoneEncrypted String?   @map("recovery_phone_encrypted")
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  name                   String?   @map("name")
  clinicId               String?   @map("clinic_id") @db.Uuid

  roles               UserRole[]
  twoFactorCodes      TwoFactorCode[]
  clinic              Clinic?              @relation("ClinicUsers", fields: [clinicId], references: [id], onDelete: SetNull)
  passwordResetTokens PasswordResetToken[]
  adminNotes          AdminNote[]

  @@map("users")
}

model UserRole {
  id     String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId String  @map("user_id") @db.Uuid
  role   AppRole

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@map("user_roles")
}

model TwoFactorCode {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  codeHash   String    @map("code_hash")
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz
  attempts   Int       @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("two_factor_codes")
}

model AuditLog {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  actorUserId    String?  @map("actor_user_id") @db.Uuid
  actorRole      String   @map("actor_role")
  ipAddress      String?  @map("ip_address")
  actionType     String   @map("action_type")
  affectedRecord String   @map("affected_record")
  previousValue  Json?    @map("previous_value")
  newValue       Json?    @map("new_value")
  notes          String?

  @@map("audit_log")
}

// ---------------------------------------------------------------------------
// Patient Journey — §3 Data model
// ---------------------------------------------------------------------------

model Patient {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String    @unique @map("user_id") @db.Uuid
  zipCode          String?   @map("zip_code")
  dateOfBirth      DateTime? @map("date_of_birth") @db.Date
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  lastAssessmentAt DateTime? @map("last_assessment_at") @db.Timestamptz
  isDeleted        Boolean   @default(false) @map("is_deleted")
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz

  assessments PatientAssessment[]
  leads       Lead[]

  @@map("patients")
}

model PatientAssessment {
  id                       String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId                String             @unique @map("session_id")
  patientId                String?            @map("patient_id") @db.Uuid
  treatmentCategory        AssessmentCategory @map("treatment_category")
  // Encrypted PHI stored as ciphertext (text)
  symptomDuration          String?            @map("symptom_duration")
  exerciseFrequency        String?            @map("exercise_frequency")
  diet                     String?            @map("diet")
  sleepHours               String?            @map("sleep_hours")
  stressLevel              String?            @map("stress_level")
  alcoholUse               String?            @map("alcohol_use")
  appointmentPreference    String?            @map("appointment_preference")
  biologicalSex            String?            @map("biological_sex")
  allergyDetails           String?            @map("allergy_details")
  otherMedications         String?            @map("other_medications")
  // Plain fields
  hasPriorTreatment        Boolean?           @map("has_prior_treatment")
  willingLabWork           Boolean?           @map("willing_lab_work")
  willingStructuredProgram Boolean?           @map("willing_structured_program")
  startTimeline            String?            @map("start_timeline")
  budgetBand               String             @map("budget_band")
  telehealthPreference     String             @map("telehealth_preference")
  pregnantOrPlanning       Boolean?           @map("pregnant_or_planning")
  takingPrescriptions      Boolean?           @map("taking_prescriptions")
  hadPriorTherapy          Boolean?           @map("had_prior_therapy")
  medicationAllergies      Boolean?           @map("medication_allergies")
  zipCode                  String             @map("zip_code")
  consentGiven             Boolean            @map("consent_given")
  consentVersion           String             @map("consent_version")
  consentGivenAt           DateTime           @map("consent_given_at") @db.Timestamptz
  submittedAt              DateTime           @map("submitted_at") @db.Timestamptz

  patient           Patient?                     @relation(fields: [patientId], references: [id], onDelete: SetNull)
  goals             AssessmentGoal[]
  symptoms          AssessmentSymptom[]
  chronicConditions AssessmentChronicCondition[]
  prescriptions     AssessmentPrescription[]
  leads             Lead[]

  @@map("patient_assessments")
}

model AssessmentGoal {
  assessmentId String @map("assessment_id") @db.Uuid
  goalCode     String @map("goal_code")

  assessment PatientAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@id([assessmentId, goalCode])
  @@map("assessment_goals")
}

model AssessmentSymptom {
  assessmentId String @map("assessment_id") @db.Uuid
  symptomCode  String @map("symptom_code")
  severity     Int

  assessment PatientAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@id([assessmentId, symptomCode])
  @@map("assessment_symptoms")
}

model AssessmentChronicCondition {
  assessmentId  String @map("assessment_id") @db.Uuid
  conditionCode String @map("condition_code")

  assessment PatientAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@id([assessmentId, conditionCode])
  @@map("assessment_chronic_conditions")
}

model AssessmentPrescription {
  assessmentId     String @map("assessment_id") @db.Uuid
  prescriptionCode String @map("prescription_code")

  assessment PatientAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@id([assessmentId, prescriptionCode])
  @@map("assessment_prescriptions")
}

model Clinic {
  id                        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug                      String    @unique
  name                      String
  about                     String?
  providerName              String?   @map("provider_name")
  websiteUrl                String?   @map("website_url")
  rating                    Decimal   @db.Decimal(2, 1)
  reviewCount               Int       @map("review_count")
  latitude                  Float?
  longitude                 Float?
  city                      String?
  stateCode                 String?   @map("state_code")
  telehealthAvailable       Boolean   @map("telehealth_available")
  newPatientWait            String?   @map("new_patient_wait")
  consultationFeeBand       String?   @map("consultation_fee_band")
  monthlyProgramBand        String?   @map("monthly_program_band")
  financingAvailable        Boolean   @map("financing_available")
  acceptsInsurance          Boolean   @map("accepts_insurance")
  status                    String
  billingStatus             String    @map("billing_status")
  businessEmail             String?   @map("business_email")
  webhookUrl                String?   @map("webhook_url")
  webhookSecret             String?   @map("webhook_secret")
  notifyOnLead              Boolean   @map("notify_on_lead")
  differentiators           String?
  offersLabWork             Boolean   @default(false) @map("offers_lab_work")
  insuranceNotes            String?   @map("insurance_notes")
  credentials               String?
  npiNumber                 String?   @map("npi_number")
  stateLicenseNumber        String?   @map("state_license_number")
  logoUrl                   String?   @map("logo_url")
  photoCount                Int       @default(0) @map("photo_count")
  weeklySummary             Boolean   @default(false) @map("weekly_summary")
  location                  String?
  webhookHealth             String    @default("unknown") @map("webhook_health")
  suspensionReason          String?   @map("suspension_reason")
  zipCode                   String?   @map("zip_code")
  isListedInDirectory       Boolean   @default(true) @map("is_listed_in_directory")
  createdAt                 DateTime  @default(now()) @map("created_at") @db.Timestamptz
  stripeCustomerId          String?   @map("stripe_customer_id")
  subscriptionActiveThrough DateTime? @map("subscription_active_through") @db.Timestamptz
  subscriptionCancelledAt   DateTime? @map("subscription_cancelled_at") @db.Timestamptz

  categories     ClinicCategory[]
  services       ClinicService[]
  leads          Lead[]
  photos         ClinicPhoto[]
  users          User[]              @relation("ClinicUsers")
  applications   ClinicApplication[]
  notes          AdminNote[]
  billingProfile BillingProfile?
  invoices       Invoice[]

  @@map("clinics")
}

model BillingProfile {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clinicId           String   @unique @map("clinic_id") @db.Uuid
  billingEmail       String?  @map("billing_email")
  billingContactName String?  @map("billing_contact_name")
  addressLine1       String?  @map("address_line1")
  addressLine2       String?  @map("address_line2")
  city               String?
  stateCode          String?  @map("state_code")
  zipCode            String?  @map("zip_code")
  taxId              String?  @map("tax_id")
  stripeCustomerId   String?  @map("stripe_customer_id")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@map("billing_profiles")
}

model Invoice {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clinicId        String    @map("clinic_id") @db.Uuid
  stripeInvoiceId String?   @map("stripe_invoice_id")
  periodStart     DateTime  @map("period_start") @db.Timestamptz
  periodEnd       DateTime  @map("period_end") @db.Timestamptz
  leadCount       Int       @map("lead_count")
  pricePerLead    Decimal   @map("price_per_lead") @db.Decimal(10, 2)
  platformFee     Decimal   @map("platform_fee") @db.Decimal(10, 2)
  totalAmount     Decimal   @map("total_amount") @db.Decimal(10, 2)
  status          String    @default("draft")
  dueDate         DateTime? @map("due_date") @db.Timestamptz
  paidAt          DateTime? @map("paid_at") @db.Timestamptz
  invoiceUrl      String?   @map("invoice_url")
  pdfUrl          String?   @map("pdf_url")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId, periodStart(sort: Desc)], map: "invoices_clinic_period_idx")
  @@map("invoices")
}

model ClinicCategory {
  clinicId String             @map("clinic_id") @db.Uuid
  category AssessmentCategory

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@id([clinicId, category])
  @@map("clinic_categories")
}

model ClinicService {
  clinicId     String  @map("clinic_id") @db.Uuid
  serviceCode  String  @map("service_code")
  isTopService Boolean @default(false) @map("is_top_service")
  displayOrder Int     @default(0) @map("display_order")

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@id([clinicId, serviceCode])
  @@map("clinic_services")
}

model ClinicPhoto {
  id           String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clinicId     String @map("clinic_id") @db.Uuid
  url          String
  displayOrder Int    @map("display_order")

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@map("clinic_photos")
}

model Lead {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadId                String    @unique @map("lead_id")
  clinicId              String    @map("clinic_id") @db.Uuid
  assessmentId          String?   @map("assessment_id") @db.Uuid
  patientId             String?   @map("patient_id") @db.Uuid
  patientFirstName      String    @map("patient_first_name")
  patientEmail          String    @map("patient_email")
  patientZip            String?   @map("patient_zip")
  treatmentCategory     String    @map("treatment_category")
  topGoals              String?   @map("top_goals")
  topSymptoms           String?   @map("top_symptoms")
  budgetBand            String?   @map("budget_band")
  telehealthPreference  String?   @map("telehealth_preference")
  appointmentPreference String?   @map("appointment_preference")
  startTimeline         String?   @map("start_timeline")
  patientPhone          String?   @map("patient_phone")
  inquiryMessage        String?   @map("inquiry_message")
  leadSource            String    @map("lead_source")
  deliveryStatus        String    @map("delivery_status")
  clinicStatus          String    @map("clinic_status")
  receivedAt            DateTime  @map("received_at") @db.Timestamptz
  deliveredAt           DateTime? @map("delivered_at") @db.Timestamptz

  clinic     Clinic             @relation(fields: [clinicId], references: [id])
  assessment PatientAssessment? @relation(fields: [assessmentId], references: [id], onDelete: SetNull)
  patient    Patient?           @relation(fields: [patientId], references: [id], onDelete: SetNull)

  webhookDeliveries WebhookDelivery[]

  @@map("leads")
}

model WebhookDelivery {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadId       String   @map("lead_id") @db.Uuid
  url          String
  status       String
  responseCode Int?     @map("response_code")
  error        String?
  attemptedAt  DateTime @map("attempted_at") @db.Timestamptz

  lead Lead @relation(fields: [leadId], references: [id])

  @@map("webhook_deliveries")
}

model ZipCode {
  zip       String @id
  latitude  Float
  longitude Float
  city      String
  stateCode String @map("state_code")

  @@map("zip_codes")
}

// ---------------------------------------------------------------------------
// Clinic Applications — §3 Data model
// ---------------------------------------------------------------------------

model ClinicApplication {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clinicName          String    @map("clinic_name")
  contactEmail        String    @map("contact_email")
  businessEmail       String?   @map("business_email")
  city                String?
  stateCode           String?   @map("state_code")
  zipCode             String?   @map("zip_code")
  websiteUrl          String?   @map("website_url")
  telehealthAvailable Boolean   @default(false) @map("telehealth_available")
  offersLabWork       Boolean   @default(false) @map("offers_lab_work")
  newPatientWait      String?   @map("new_patient_wait")
  npiNumber           String?   @map("npi_number")
  stateLicenseNumber  String?   @map("state_license_number")
  consultationFeeBand String?   @map("consultation_fee_band")
  monthlyProgramBand  String?   @map("monthly_program_band")
  financingAvailable  Boolean   @default(false) @map("financing_available")
  insuranceAccepted   Boolean   @default(false) @map("insurance_accepted")
  insuranceNotes      String?   @map("insurance_notes")
  about               String?
  differentiators     String?
  providerName        String?   @map("provider_name")
  credentials         String?
  logoUrl             String?   @map("logo_url")
  photoUrls           Json?     @map("photo_urls")
  status              String    @default("pending")
  denyReason          String?   @map("deny_reason")
  reviewedAt          DateTime? @map("reviewed_at") @db.Timestamptz
  reviewedByUserId    String?   @map("reviewed_by_user_id") @db.Uuid
  createdClinicId     String?   @map("created_clinic_id") @db.Uuid
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  createdClinic Clinic?               @relation(fields: [createdClinicId], references: [id], onDelete: SetNull)
  categories    ApplicationCategory[]
  services      ApplicationService[]

  @@map("clinic_applications")
}

model ApplicationCategory {
  applicationId String             @map("application_id") @db.Uuid
  category      AssessmentCategory

  application ClinicApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@id([applicationId, category])
  @@map("application_categories")
}

model ApplicationService {
  id            String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  applicationId String  @map("application_id") @db.Uuid
  serviceCode   String  @map("service_code")
  isTopService  Boolean @default(false) @map("is_top_service")
  displayOrder  Int     @map("display_order")

  application ClinicApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("application_services")
}

model PasswordResetToken {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @map("token_hash")
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model AdminNote {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clinicId     String   @map("clinic_id") @db.Uuid
  authorUserId String   @map("author_user_id") @db.Uuid
  authorName   String   @map("author_name")
  body         String
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [authorUserId], references: [id], onDelete: Restrict)

  @@index([clinicId, createdAt(sort: Desc)], map: "admin_notes_clinic_created_idx")
  @@map("admin_notes")
}

# Application
NODE_ENV=development
PORT=3000

# Database (Supabase Postgres)
DATABASE_URL=postgresql://postgres:password@localhost:5432/medalign

# JWT
JWT_SECRET=your-super-secret-jwt-signing-key-must-be-at-least-32-chars
JWT_EXPIRY_MINUTES=60

# Encryption (base64-encoded 32-byte key; generate with: openssl rand -base64 32)
ENCRYPTION_KEY=VZbmMdiVnQiIQXt1jRimhBt1UWe5anTdyMtcxJzJ6UM=

# SendGrid
SENDGRID_API_KEY=SG.your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@medalign.com

# App
APP_BASE_URL=http://localhost:3000

# Cookie domain (optional, e.g. .medalign.com in prod)
# COOKIE_DOMAIN=

# Claim token HMAC secret (generate: openssl rand -hex 32)
CLAIM_TOKEN_SECRET=your-claim-token-secret-must-be-at-least-32-chars

# Supabase Storage (clinic portal media uploads via signed URLs)
# SUPABASE_URL: your project URL, e.g. https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY: service-role key (server-side only, never exposed to clients)
# SUPABASE_STORAGE_BUCKET: public-read bucket for clinic logos/photos (default: clinic-media)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_STORAGE_BUCKET=clinic-media

# Stripe (billing) — this must be a test-mode secret key (sk_test_...); never use a live key locally
STRIPE_SECRET_KEY=sk_test_placeholder

{
  "openapi": "3.0.0",
  "paths": {
    "/health": {
      "get": {
        "description": "Returns OK when the service is running.",
        "operationId": "HealthController_check",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "example": {
                    "status": "ok"
                  }
                }
              }
            }
          }
        },
        "summary": "Health check",
        "tags": [
          "Health"
        ]
      }
    },
    "/auth/signup": {
      "post": {
        "description": "Creates a new user account and triggers a 2FA email.",
        "operationId": "AuthController_signup",
        "parameters": [
          {
            "name": "x-csrf-token",
            "in": "header",
            "description": "CSRF token — required on all non-GET requests. Value is provided by the server.",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignupDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created",
            "content": {
              "application/json": {
                "schema": {
                  "example": {
                    "userId": "uuid-here"
                  }
                }
              }
            }
          },
          "409": {
            "description": "Email already registered"
          },
          "422": {
            "description": "Validation error"
          }
        },
        "summary": "Register a new user",
        "tags": [
          "Auth"
        ]
      }
    },
    "/auth/signin": {
      "post": {
        "description": "Validates credentials and triggers a 2FA email. The session is only established after POST /auth/2fa/verify.",
        "operationId": "AuthController_signin",
        "parameters": [
          {
            "name": "x-csrf-token",
            "in": "header",
            "description": "CSRF token — required on all non-GET requests. Value is provided by the server.",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SigninDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "2FA code sent",
            "content": {
              "application/json": {
                "schema": {
                  "example": {
                    "requiresTwoFactor": true
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials"
          },
          "403": {
            "description": "Account locked"
          }
        },
        "summary": "Sign in with email and password",
        "tags": [
          "Auth"
        ]
      }
    },
    "/auth/2fa/verify": {
      "post": {
        "description": "Validates the OTP emailed after sign-in. On success, sets an HttpOnly `access_token` cookie that authenticates subsequent requests.",
        "operationId": "AuthController_verify",
        "parameters": [
          {
            "name": "x-csrf-token",
            "in": "header",
            "description": "CSRF token — required on all non-GET requests. Value is provided by the server.",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Verify2faDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authentication successful — access_token cookie set",
            "content": {
              "application/json": {
                "schema": {
                  "example": {
                    "userId": "uuid-here",
                    "role": "patient"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid or expired OTP"
          }
        },
        "summary": "Verify 2FA code and obtain session",
        "tags": [
          "Auth"
        ]
      }
    },
    "/auth/2fa/send": {
      "post": {
        "description": "Generates and emails a new OTP for the given address. Rate-limited.",
        "operationId": "AuthController_resend",
        "parameters": [
          {
            "name": "x-csrf-token",
            "in": "header",
            "description": "CSRF token — required on all non-GET requests. Value is provided by the server.",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Resend2faDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "2FA code sent",
            "content": {
              "application/json": {
                "schema": {
                  "example": {
                    "ok": true
                  }
                }
              }
            }
          }
        },
        "summary": "Resend 2FA code",
        "tags": [
          "Auth"
        ]
      }
    },
    "/auth/signout": {
      "post": {
        "description": "Invalidates the current session and clears the access_token cookie.",
        "operationId": "AuthController_signout",
        "parameters": [
          {
            "name": "x-csrf-token",
            "in": "header",
            "description": "CSRF token — required on all non-GET requests. Value is provided by the server.",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Signed out",
            "content": {
              "application/json": {
                "schema": {
                  "example": {
                    "ok": true
                  }
                }
              }
            }
          },
          "401": {
            "description": "Not authenticated"
          }
        },
        "security": [
          {
            "access_token": []
          }
        ],
        "summary": "Sign out",
        "tags": [
          "Auth"
        ]
      }
    },
    "/auth/me": {
      "get": {
        "description": "Returns the authenticated user's profile. Requires a valid access_token cookie.",
        "operationId": "AuthController_me",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Current user info",
            "content": {
              "application/json": {
                "schema": {
                  "example": {
                    "userId": "uuid-here",
                    "email": "user@example.com",
                    "role": "patient"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Not authenticated"
          }
        },
        "security": [
          {
            "access_token": []
          }
        ],
        "summary": "Get current user",
        "tags": [
          "Auth"
        ]
      }
    },
    "/assessments": {
      "post": {
        "operationId": "AssessmentsController_submit",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SubmitAssessmentDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": ""
          }
        },
        "tags": [
          "Assessments"
        ]
      }
    },
    "/assessments/latest": {
      "get": {
        "operationId": "AssessmentsController_getLatest",
        "parameters": [
          {
            "name": "sessionId",
            "required": true,
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "claimToken",
            "required": true,
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "tags": [
          "Assessments"
        ]
      }
    },
    "/recommendations/{sessionId}": {
      "get": {
        "operationId": "RecommendationsController_getRecommendationsForSession",
        "parameters": [
          {
            "name": "sessionId",
            "required": true,
            "in": "path",
            "description": "Assessment session ID (session_<32 hex>)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Ranked clinic matches (no PHI)"
          },
          "404": {
            "description": "Assessment not found or invalid session ID"
          }
        },
        "summary": "Get clinic recommendations for a patient session",
        "tags": [
          "recommendations"
        ]
      }
    },
    "/leads": {
      "post": {
        "operationId": "LeadsController_submit",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SubmitLeadDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Lead created; returns the lead id."
          },
          "404": {
            "description": "Clinic not found."
          }
        },
        "summary": "Submit a lead to a clinic (anonymous or authenticated)",
        "tags": [
          "leads"
        ]
      }
    },
    "/patients/me": {
      "get": {
        "operationId": "PatientsController_getMe",
        "parameters": [],
        "responses": {
          "200": {
            "description": ""
          },
          "401": {
            "description": ""
          },
          "404": {
            "description": ""
          }
        },
        "security": [
          {
            "access_token": []
          }
        ],
        "summary": "Get the authenticated patient profile",
        "tags": [
          "patients"
        ]
      },
      "put": {
        "operationId": "PatientsController_putMe",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateProfileDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": ""
          },
          "401": {
            "description": ""
          },
          "404": {
            "description": ""
          }
        },
        "security": [
          {
            "access_token": []
          }
        ],
        "summary": "Update the authenticated patient profile",
        "tags": [
          "patients"
        ]
      }
    },
    "/patients/me/leads": {
      "get": {
        "operationId": "PatientsController_getMyLeadsHandler",
        "parameters": [],
        "responses": {
          "200": {
            "description": ""
          },
          "401": {
            "description": ""
          }
        },
        "security": [
          {
            "access_token": []
          }
        ],
        "summary": "Get the authenticated patient lead history",
        "tags": [
          "patients"
        ]
      }
    }
  },
  "info": {
    "title": "MedAlign Backend API",
    "description": "MedAlign backend API. Authentication uses an HttpOnly `access_token` cookie set on POST /auth/2fa/verify. All non-GET requests require an `x-csrf-token` header matching the value returned by the CSRF middleware.",
    "version": "0.1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "cookie": {
        "type": "apiKey",
        "in": "cookie",
        "name": "access_token"
      }
    },
    "schemas": {
      "SignupDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@example.com",
            "description": "User email address"
          },
          "password": {
            "type": "string",
            "example": "MySecurePass1!",
            "description": "Password (min 8 characters)",
            "minLength": 8
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "SigninDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@example.com",
            "description": "User email address"
          },
          "password": {
            "type": "string",
            "example": "MySecurePass1!",
            "description": "User password"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "Verify2faDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@example.com",
            "description": "User email address"
          },
          "code": {
            "type": "string",
            "example": "123456",
            "description": "6-digit OTP code received by email"
          }
        },
        "required": [
          "email",
          "code"
        ]
      },
      "Resend2faDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@example.com",
            "description": "User email address to resend the 2FA code to"
          }
        },
        "required": [
          "email"
        ]
      },
      "SubmitAssessmentDto": {
        "type": "object",
        "properties": {}
      },
      "SubmitLeadDto": {
        "type": "object",
        "properties": {}
      },
      "UpdateProfileDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 200
          },
          "dob": {
            "type": "string"
          }
        },
        "required": [
          "name"
        ]
      }
    }
  }
}